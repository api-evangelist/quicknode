  "info": {
    "_postman_id": "4b16ca59-9d17-4ea3-bcef-be53be678dbc",
    "name": "QuickNode Streams REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The QuickNode Streams REST API allows developers to create, manage, and monitor Streams, QuickNode's customizable real-time blockchain data feed service. Streams can be configured to deliver filtered event-driven data over destinations such as webhooks or storage targets. The REST API supports listing, creating, pausing, resuming, and inspecting streams, as well as retrieving execution logs.\n\nContact Support:\n Name: QuickNode Support",
      "type": "text/plain"
    }
  }
